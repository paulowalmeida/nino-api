{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit 2>&1 | head -20",
            "timeout": 30,
            "statusMessage": "Verificando tipos..."
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "sh .claude/hooks/on-mcp-call.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
