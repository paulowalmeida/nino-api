{
  "name": "nino",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "fuser -k 3000/tcp; nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:ci": "eslint \"{src,apps,libs,test}/**/*.ts\" --max-warnings=0",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma-case-format --file ./prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "seed": "ts-node -r tsconfig-paths/register src/config/database/seed/seed.ts",
    "docker:up-d": "docker compose up -d",
    "docker:up": "docker compose up",
    "docker:down-v": "docker compose down -v",
    "docker:down": "docker compose down",
    "db:wait": "until docker exec nino_api_db pg_isready -U postgres; do sleep 1; done",
    "reset": "npm run docker:down-v && npm run docker:up-d && npm run db:wait && npm run prisma:format && npm run prisma:migrate && npm run seed"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.7",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "dotenv-cli": "^11.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/core": "^1.15.33",
    "@swc/jest": "^0.2.39",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.4",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "prisma-case-format": "^2.2.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "@swc/jest",
        {
          "jsc": {
            "parser": {
              "syntax": "typescript",
              "decorators": true,
              "dynamicImport": true
            },
            "transform": {
              "legacyDecorator": true,
              "decoratorMetadata": true
            },
            "target": "es2021",
            "keepClassNames": true
          },
          "module": {
            "type": "commonjs"
          }
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.module.ts",
      "!**/*.type.ts",
      "!**/types/**",
      "!**/*.enum.ts",
      "!**/main.ts",
      "!**/*.dto.ts",
      "!**/seed.**",
      "!**/**.entity.ts",
      "!**/mocks/**"
    ],
    "coverageDirectory": "../coverage",
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "functions": 80,
        "branches": 80,
        "statements": 80
      }
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@auth/(.*)$": "<rootDir>/modules/auth/$1",
      "^@business-category/(.*)$": "<rootDir>/modules/company/modules/business-category/$1",
      "^@company/(.*)$": "<rootDir>/modules/company/$1",
      "^@company-responsible/(.*)$": "<rootDir>/modules/company/modules/company-responsible/$1",
      "^@credential/(.*)$": "<rootDir>/modules/user/modules/credential/$1",
      "^@invoice-status/(.*)$": "<rootDir>/modules/invoice-status/$1",
      "^@mocks/(.*)$": "<rootDir>/mocks/$1",
      "^@notification-type/(.*)$": "<rootDir>/modules/notification-type/$1",
      "^@plan/(.*)$": "<rootDir>/modules/plan/$1",
      "^@plan-type/(.*)$": "<rootDir>/modules/plan-type/$1",
      "^@role/(.*)$": "<rootDir>/modules/role/$1",
      "^@session/(.*)$": "<rootDir>/modules/session/$1",
      "^@shared/(.*)$": "<rootDir>/shared/$1",
      "^@courier/(.*)$": "<rootDir>/modules/courier/$1",
      "^@order/(.*)$": "<rootDir>/modules/order/$1",
      "^@order-status/(.*)$": "<rootDir>/modules/order-status/$1",
      "^@courier-tenant/(.*)$": "<rootDir>/modules/courier/modules/courier-tenant/$1",
      "^@subscription/(.*)$": "<rootDir>/modules/subscription/$1",
      "^@subscription-status/(.*)$": "<rootDir>/modules/subscription-status/$1",
      "^@tenant/(.*)$": "<rootDir>/modules/tenant/$1",
      "^@tenant-phone/(.*)$": "<rootDir>/modules/tenant/modules/tenant-phone/$1",
      "^@tenant-settings/(.*)$": "<rootDir>/modules/tenant/modules/tenant-settings/$1",
      "^@tenant-status/(.*)$": "<rootDir>/modules/tenant/modules/tenant-status/$1",
      "^@tenant-type/(.*)$": "<rootDir>/modules/tenant/modules/tenant-type/$1",
      "^@opening-hours/(.*)$": "<rootDir>/modules/tenant/modules/opening-hours/$1",
      "^@customer/(.*)$": "<rootDir>/modules/customer/$1",
      "^@customer-address/(.*)$": "<rootDir>/modules/customer/modules/customer-address/$1",
      "^@customer-tenant/(.*)$": "<rootDir>/modules/customer/modules/customer-tenant/$1",
      "^@customer-payment-method/(.*)$": "<rootDir>/modules/customer/modules/customer-payment-method/$1",
      "^@payment-method/(.*)$": "<rootDir>/modules/payment-method/$1",
      "^@user/(.*)$": "<rootDir>/modules/user/$1",
      "^@user-tenant/(.*)$": "<rootDir>/modules/user-tenant/$1"
    }
  },
  "overrides": {
    "get-up": "npm:find-up@5.0.0"
  }
}
