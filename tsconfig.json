{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "strictPropertyInitialization": false,
    "types": ["jest", "node"],
    "paths": {
      "@auth/*": ["src/modules/auth/*"],
      "@business-category/*": ["src/modules/company/modules/business-category/*"],
      "@company/*": ["src/modules/company/*"],
      "@company-responsible/*": ["src/modules/company/modules/company-responsible/*"],
      "@credential/*": ["src/modules/user/modules/credential/*"],
      "@global-role/*": ["src/modules/global-role/*"],
      "@invoice-status/*": ["src/modules/invoice-status/*"],
      "@health/*": ["src/modules/health/*"],
      "@mocks/*": ["src/mocks/*"],
      "@notification-type/*": ["src/modules/notification-type/*"],
      "@plan/*": ["src/modules/plan/*"],
      "@plan-type/*": ["src/modules/plan/modules/plan-type/*"],
      "@session/*": ["src/modules/session/*"],
      "@shared/*": ["src/shared/*"],
      "@courier/*": ["src/modules/courier/*"],
      "@courier-tenant/*": ["src/modules/courier/modules/courier-tenant/*"],
      "@subscription/*": ["src/modules/subscription/*"],
      "@subscription-status/*": ["src/modules/subscription-status/*"],
      "@tenant-role/*": ["src/modules/tenant-role/*"],
      "@tenant/*": ["src/modules/tenant/*"],
      "@tenant-phone/*": ["src/modules/tenant/modules/tenant-phone/*"],
      "@tenant-settings/*": ["src/modules/tenant/modules/tenant-settings/*"],
      "@tenant-status/*": ["src/modules/tenant/modules/tenant-status/*"],
      "@tenant-type/*": ["src/modules/tenant/modules/tenant-type/*"],
      "@opening-hours/*": ["src/modules/tenant/modules/opening-hours/*"],
      "@customer/*": ["src/modules/customer/*"],
      "@customer-address/*": ["src/modules/customer/modules/customer-address/*"],
      "@customer-tenant/*": ["src/modules/customer/modules/customer-tenant/*"],
      "@customer-payment-method/*": ["src/modules/customer/modules/customer-payment-method/*"],
      "@payment-method/*": ["src/modules/payment-method/*"],
      "@user/*": ["src/modules/user/*"],
      "@user-tenant/*": ["src/modules/user/modules/user-tenant/*"],
      "@product/*": ["src/modules/product/*"],
      "@product-category/*": ["src/modules/product/modules/product-category/*"],
    }
  }
}
