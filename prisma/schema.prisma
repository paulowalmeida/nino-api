generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. TABELAS BASE / DOMÍNIOS ESTÁTICOS (Nenhuma dependência)
// ==========================================

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  users       User[]

  @@map("roles")
}

model TenantStatus {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  tenants     Tenant[]

  @@map("tenant_statuses")
}

model SubscriptionStatus {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  subscriptions Subscription[]

  @@map("subscription_statuses")
}

model InvoiceStatus {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  invoices    Invoice[]

  @@map("invoice_statuses")
}

model NotificationType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  notifications Notification[]

  @@map("notification_types")
}

model PlanType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  plans       Plan[]

  @@map("plan_types")
}

// ==========================================
// 2. ENTIDADE PRINCIPAL INDEPENDENTE
// ==========================================

model Company {
  id                String    @id @default(uuid())
  companyName       String
  cnpj              String    @unique
  legalName         String?
  stateRegistration String?
  legalNature       String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  users              User[]
  tenants            Tenant[]
  subscription       Subscription?
  companyResponsible CompanyResponsible?

  @@map("companies")
}

// ==========================================
// 3. ENTIDADES DE 1º NÍVEL DE DEPENDÊNCIA
// ==========================================

model Plan {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique
  typeId      String
  price       Decimal
  maxTenants  Int
  maxProducts Int
  maxOrders   Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  type          PlanType       @relation(fields: [typeId], references: [id])
  subscriptions Subscription[]

  @@map("plans")
}

model CompanyResponsible {
  id        String   @id @default(uuid())
  companyId String   @unique
  name      String
  cpf       String   @unique
  email     String
  phone     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_responsibles")
}

model User {
  id                String    @id @default(uuid())
  companyId         String?
  name              String
  roleId            String
  isActive          Boolean   @default(true)
  lastLoginAt       DateTime?
  locale            String?
  timezone          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  role              Role      @relation(fields: [roleId], references: [id])
  company           Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  credentials       AuthCredential[]
  sessions          Session[]
  notifications     Notification[]
  auditLogs         AuditLog[]

  @@map("users")
}

// ==========================================
// 4. ENTIDADES DE 2º NÍVEL DE DEPENDÊNCIA
// ==========================================

model AuthCredential {
  id                 String   @id @default(uuid())
  userId             String
  email              String?  @unique
  password           String?
  provider           String   @default("local")
  providerId         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("auth_credentials")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique 
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  typeId    String
  title     String
  body      String
  isRead    Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type NotificationType @relation(fields: [typeId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String   
  entity    String   
  entityId  String?
  details   Json?    
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("audit_logs")
}

model Tenant {
  id               String   @id @default(uuid())
  companyId        String
  name             String
  slug             String   @unique
  statusId         String
  logoUrl          String?
  primaryColor     String?
  secondaryColor   String?
  favicon          String?
  customDomain     String?  @unique
  phone            String?      
  email            String?      
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  status        TenantStatus   @relation(fields: [statusId], references: [id])
  tenantAddress TenantAddress?

  @@map("tenants")
}

model Subscription {
  id        String   @id @default(uuid())
  companyId String   @unique
  planId    Int
  statusId  String
  startedAt DateTime @default(now())
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan     Plan               @relation(fields: [planId], references: [id])
  status   SubscriptionStatus @relation(fields: [statusId], references: [id])
  invoices Invoice[] 

  @@map("subscriptions")
}

// ==========================================
// 5. ENTIDADES DE 3º NÍVEL DE DEPENDÊNCIA (As pontas)
// ==========================================

model TenantAddress {
  id         String   @id @default(uuid())
  tenantId   String   @unique
  cep        String?
  street     String?
  number     String?
  complement String?
  city       String?
  state      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_addresses")
}

model Invoice {
  id             String   @id @default(uuid())
  subscriptionId String
  amount         Decimal
  statusId       String
  dueDate        DateTime
  paidAt         DateTime?
  paymentGateway String?  
  gatewayId      String?  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscription Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  status       InvoiceStatus @relation(fields: [statusId], references: [id])

  @@map("invoices")
}